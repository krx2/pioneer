# Copy this file to .env and fill in real values. Never commit .env itself.

# Local LLM, served behind an OpenAI-compatible endpoint (Ollama, llama.cpp, vLLM, ...).
PIONEER_LLM_BASE_URL=http://localhost:11434/v1
PIONEER_LLM_MODEL=

# Only needed if your local server is configured to require one. Leave blank otherwise.
PIONEER_LLM_API_KEY=

# Dedicated Satisfactory server connection info.
PIONEER_SERVER_HOST=
PIONEER_SERVER_PORT=
